{
  "name": "remote-terminal-bridge",
  "version": "0.1.0",
  "description": "Access and manage terminal sessions remotely via web browser, mobile app, or Feishu bot. Single binary, zero dependencies.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeweiz/remote-desktop-control.git"
  },
  "keywords": [
    "terminal",
    "remote-terminal",
    "web-terminal",
    "xterm",
    "pty",
    "websocket",
    "cloudflare-tunnel",
    "feishu",
    "lark",
    "mobile",
    "expo",
    "react-native",
    "session-manager"
  ],
  "bin": {
    "rtb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:binary": "tsc && node build-binary.mjs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
