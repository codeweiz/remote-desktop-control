{
  "name": "remote-terminal-bridge",
  "version": "0.1.0",
  "description": "Remote terminal bridge with WebSocket and Feishu integration",
  "type": "module",
  "bin": {
    "rtb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:binary": "tsc && pkg . --compress GZip"
  },
  "pkg": {
    "targets": ["node18-linux-x64", "node18-linux-arm64", "node18-macos-x64", "node18-macos-arm64"],
    "assets": ["web/**/*"],
    "outputPath": "release"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@yao-pkg/pkg": "^6.14.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
